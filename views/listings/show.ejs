<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3 class="mb-3"><%= listing.title %></h3>
    </div>

    <div class="col-8 offset-2 show-card">
        <img 
            src="<%= listing.image.url %>" 
            class="card-img-top show-img mb-3" 
            alt="listing_image"
        >
        
        <div class="card-body">
            <p class="card-text text-muted mb-1">
                Hosted in: <%= listing.location %>, <%= listing.country %>
            </p>
            
            <p class="card-text description-text mb-3">
                <%= listing.description %>
            </p>
            
            <p class="card-text price-text mb-4">
                &#8377; <%= listing.price.toLocaleString("en-IN") %> <span class="text-muted fw-normal">/ night</span>
            </p>
        </div>

        <div class="btns mb-5">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">
                Edit
            </a>
            
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                <button class="btn btn-dark delete-btn">
                    Delete
                </button>
            </form>
        </div>
    </div>
</div>